rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles + watchlist/watched lists. Keyed by Firebase Auth uid.
    // Publicly readable (for friends, creator lists, shared watchlists).
    // Writable only by the owner.
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;

      // Friend edges:
      //  - Pending or blocked edges = visible only to either party
      //  - Accepted edges = readable by any authed user (powers mutuals
      //    + friends-of-friends discovery; profile graph already public)
      // Writes always restricted to either party of the edge.
      match /friends/{friendUid} {
        allow read: if request.auth != null && (
          request.auth.uid == uid
          || request.auth.uid == friendUid
          || resource.data.status == "accepted"
        );
        allow create, update, delete:
          if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }

      // Inbox: any authed user may create a rec doc if fromUid matches
      // their own uid. Only the inbox owner may read, update, or delete.
      match /inbox/{recId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.resource.data.fromUid == request.auth.uid;
      }

      // Everything else under /users/{uid} is owner-only.
      match /{other=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Chat between two users. chatId = sorted([uidA, uidB]).join("_").
    // Doc shape: { participants: [uidA, uidB], lastMessage, lastAt, unread: { [uid]: count } }
    match /chats/{chatId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;
      // Either participant can update doc (needed: sender sets receiver's
      // unread count, opener resets own count). Trust at app layer; phase
      // later harden field-level if abuse.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.fromUid
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Authors can edit/delete own messages
        allow update, delete: if request.auth != null
                              && request.auth.uid == resource.data.fromUid;
      }
    }

    // Handle registry: handles/{handle} -> { uid, claimedAt }
    match /handles/{handle} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
