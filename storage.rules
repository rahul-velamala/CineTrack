rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Chat image attachments. Path: chat-images/{chatId}/{filename}
    // Read = public (urls are obscure enough; chatId requires both uids)
    // Write = only authed participant of that chat, max 5MB, image/*
    match /chat-images/{chatId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/chats/$(chatId))
                   && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // User profile photos. Path: profile-photos/{uid}/{filename}
    // Public read; owner-only write up to 2MB.
    match /profile-photos/{uid}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
